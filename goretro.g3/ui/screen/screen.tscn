    //float grid_x = mod(SCREEN_UV.x * SCREEN_PIXEL_SIZE.z / grid_size, 2.0);
    //float grid_y = mod(SCREEN_UV.y * SCREEN_PIXEL_SIZE.w / grid_size, 2.0);
    
    // Si estamos en una línea de rejilla, oscurecemos ligeramente el color
